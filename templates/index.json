          "settings": {
            "text": "<p>Need reinforcing steel for your next project? Call <strong>0800 PRIME STEEL</strong> or send us a message — our team will help with product selection, stock availability and delivery.</p>"
          }
        },
        "cta_button": {
          "type": "button",
          "settings": {
            "button_label": "Get in Touch",
            "button_link": "shopify://pages/contact",
            "button_style_secondary": false,
            "button_label_2": "",
            "button_link_2": "",
            "button_style_secondary_2": false
          }
        }
      },
      "block_order": ["cta_heading", "cta_text", "cta_button"],
      "settings": {
        "desktop_content_position": "center",
