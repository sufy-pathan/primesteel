        "delivery_heading": {
          "type": "heading",
          "settings": {
            "heading": "Delivery Across Auckland",
            "heading_size": "h1"
          }
        },
        "delivery_text": {
          "type": "text",
          "settings": {
            "text": "<p>We deliver reinforcing steel to job sites throughout Auckland — including Henderson, Westgate, Albany, Silverdale, Manukau, Papakura, Pukekohe and surrounding suburbs. Same-day and next-day options available for in-stock items. Call us to arrange delivery to your site.</p>",
            "text_style": "body"
          }
        },
        "delivery_button": {
          "type": "button",
          "settings": {
            "button_label": "Arrange Delivery",
            "button_link": "shopify://pages/contact",
            "button_style_secondary": false
          }
        }
      },
      "block_order": ["delivery_heading", "delivery_text", "delivery_button"],
      "settings": {
        "height": "medium",
        "desktop_image_width": "medium",
        "layout": "text_first",
        "desktop_content_position": "middle",
        "desktop_content_alignment": "left",
        "content_layout": "no-overlap",
        "section_color_scheme": "",
        "color_scheme": "background-1",
        "image_behavior": "none",
        "mobile_content_alignment": "left",
        "padding_top": 56,
        "padding_bottom": 56
      }
    },
    "featured_products": {
      "type": "featured-collection",
      "settings": {
        "title": "Featured Products",
        "heading_size": "h1",
        "description": "",
