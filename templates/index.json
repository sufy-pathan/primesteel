            "link_label": "",
            "link": ""
          }
        },
        "trust_pricing": {
          "type": "column",
          "settings": {
            "title": "Competitive Pricing",
            "text": "<p>Trade-friendly rates on reinforcing bar, mesh and accessories.</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": ["trust_compliant", "trust_delivery", "trust_stock", "trust_pricing"],
      "settings": {
        "title": "",
        "heading_size": "h1",
        "image_width": "third",
        "image_ratio": "adapt",
        "columns_desktop": 4,
        "column_alignment": "center",
        "background_style": "primary",
        "button_label": "",
        "button_link": "",
        "color_scheme": "accent-1",
        "columns_mobile": "1",
        "swipe_on_mobile": false,
        "padding_top": 40,
        "padding_bottom": 40
