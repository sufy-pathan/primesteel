{
  "sections": {
    "hero_banner": {
      "type": "image-banner",
      "blocks": {
        "hero_heading": {
          "type": "heading",
          "settings": {
            "heading": "Prime Steel — Reinforcing Supplies",
            "heading_size": "hxl"
          }
        },
        "hero_text": {
          "type": "text",
          "settings": {
            "text": "Bulk steel supplies in stock across Auckland. AS/NZS 4671 compliant reinforcing bar, mesh and accessories — ready for delivery.",
            "text_style": "subtitle"
          }
        },
        "hero_buttons": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Shop Products",
            "button_link_1": "shopify://collections/all",
            "button_style_secondary_1": false,
            "button_label_2": "Contact Us",
            "button_link_2": "shopify://pages/contact",
            "button_style_secondary_2": true
          }
        }
      },
      "block_order": ["hero_heading", "hero_text", "hero_buttons"],
      "settings": {
        "image_overlay_opacity": 50,
        "image_height": "large",
        "desktop_content_position": "middle-left",
        "show_text_box": true,
        "desktop_content_alignment": "left",
        "color_scheme": "background-2",
        "image_behavior": "none",
        "mobile_content_alignment": "center",
        "stack_images_on_mobile": true,
        "show_text_below": true
      }
    },
    "about_prime_steel": {
      "type": "image-with-text",
      "blocks": {
        "about_heading": {
          "type": "heading",
          "settings": {
            "heading": "About Prime Steel",
            "heading_size": "h1"
          }
        },
        "about_text": {
          "type": "text",
          "settings": {
            "text": "<p>Prime Steel is an Auckland-based reinforcing steel supplier serving builders, contractors and trade customers across the region. We stock quality reinforcing bar, steel mesh and accessories to AS/NZS 4671 standards — with competitive pricing and reliable local delivery.</p>",
            "text_style": "body"
          }
        },
        "about_button": {
          "type": "button",
          "settings": {
            "button_label": "View Products",
            "button_link": "shopify://collections/all",
            "button_style_secondary": false
          }
        }
      },
      "block_order": ["about_heading", "about_text", "about_button"],
      "settings": {
        "height": "medium",
        "desktop_image_width": "medium",
        "layout": "image_first",
        "desktop_content_position": "middle",
        "desktop_content_alignment": "left",
        "content_layout": "no-overlap",
        "section_color_scheme": "",
        "color_scheme": "background-1",
        "image_behavior": "none",
        "mobile_content_alignment": "left",
        "padding_top": 56,
        "padding_bottom": 56
      }
    },
    "product_categories": {
      "type": "multicolumn",
      "blocks": {
        "cat_rebar": {
          "type": "column",
          "settings": {
            "title": "Reinforcing Bar",
            "text": "<p>Grade 500E deformed bar in standard lengths. Cut-to-size available on request.</p>",
            "link_label": "Browse Rebar",
            "link": "shopify://collections/reinforcing-bar"
          }
        },
        "cat_mesh": {
          "type": "column",
          "settings": {
            "title": "Steel Mesh",
            "text": "<p>SL, RL and trench mesh sheets for slabs, driveways and footings.</p>",
            "link_label": "Browse Mesh",
            "link": "shopify://collections/steel-mesh"
          }
        },
        "cat_accessories": {
          "type": "column",
          "settings": {
            "title": "Accessories",
            "text": "<p>Bar chairs, tie wire, spacers and fixing products for every job.</p>",
            "link_label": "Browse Accessories",
            "link": "shopify://collections/accessories"
          }
        },
        "cat_bulk": {
          "type": "column",
          "settings": {
            "title": "Bulk Orders",
            "text": "<p>Volume pricing for commercial projects and repeat trade customers.</p>",
            "link_label": "Request a Quote",
            "link": "shopify://pages/contact"
          }
        }
      },
      "block_order": ["cat_rebar", "cat_mesh", "cat_accessories", "cat_bulk"],
      "settings": {
        "title": "Product Categories",
        "heading_size": "h1",
        "image_width": "full",
        "image_ratio": "adapt",
        "columns_desktop": 4,
        "column_alignment": "left",
        "background_style": "none",
        "button_label": "",
        "button_link": "",
        "color_scheme": "background-1",
        "columns_mobile": "1",
        "swipe_on_mobile": false,
        "padding_top": 48,
        "padding_bottom": 48
      }
    },
    "trust_badges": {
      "type": "multicolumn",
      "blocks": {
        "trust_compliant": {
          "type": "column",
          "settings": {
            "title": "AS/NZS 4671 Compliant",
