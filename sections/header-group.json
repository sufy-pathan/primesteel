{
  "name": "t:sections.header.name",
  "type": "header",
  "sections": {
    "announcement-bar": {
      "type": "announcement-bar",
      "blocks": {
        "announcement_phone": {
          "type": "announcement",
          "settings": {
            "text": "CALL 0800 PRIME STEEL — Auckland reinforcing steel specialists",
            "link": "tel:08007746335"
          }
        },
        "announcement_contact": {
          "type": "announcement",
          "settings": {
            "text": "Contact Us for stock availability & delivery",
            "link": "shopify://pages/contact"
          }
        }
      },
      "block_order": ["announcement_phone", "announcement_contact"],
      "settings": {
        "color_scheme": "background-2",
        "show_line_separator": true,
        "show_social": false,
        "auto_rotate": false,
        "change_slides_speed": 5,
        "enable_country_selector": false,
        "enable_language_selector": false
      }
    },
    "header": {
      "type": "header",
      "custom_css": [
        ".header__menu-item { text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; font-size: 1.2rem; }",
        ".header__active-menu-item { color: #C41E24; }"
      ],
      "settings": {
        "logo_position": "middle-left",
        "menu": "main-menu",
        "menu_type_desktop": "dropdown",
        "sticky_header_type": "always",
        "show_line_separator": true,
        "color_scheme": "background-1",
        "menu_color_scheme": "",
        "enable_country_selector": false,
        "enable_language_selector": false,
        "mobile_logo_position": "center",
        "margin_bottom": 0,
        "padding_top": 8,
        "padding_bottom": 8
      }
    }
  },
  "order": ["announcement-bar", "header"]
}
